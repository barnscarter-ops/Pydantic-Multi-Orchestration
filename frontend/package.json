{
  "name": "multi-agent-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron electron/main.js",
    "dist": "vite build && electron-builder",
    "dist:win": "pwsh -File build-win.ps1"
  },
  "build": {
    "appId": "com.homelab.orchestrator",
    "productName": "Orchestrator",
    "copyright": "Copyright © 2026 Carter Barns",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "backend",
        "filter": [
          "*.py",
          ".env",
          "requirements.txt",
          "frontend/dist/**/*"
        ]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orchestrator"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.4.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.0"
  }
}
